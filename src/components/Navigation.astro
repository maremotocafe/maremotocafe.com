---
import { siteConfig, navigation } from "../data/site";
---

<section class="sticky top-0 z-50 bg-[#1d2024] shadow-lg shadow-black/20">
  <div class="mx-auto max-w-6xl px-4">
    <nav class="flex flex-wrap items-center justify-between py-3">
      <div class="flex items-center">
        <a href="/" class="p-0">
          <img
            src={siteConfig.logo}
            alt={siteConfig.title}
            width="557"
            height="67"
            class="h-8 w-auto sm:h-10"
          />
        </a>
      </div>

      <!-- Mobile toggle -->
      <button
        id="nav-toggle"
        class="shrink-0 rounded p-2 text-text hover:bg-white/10 lg:hidden"
        aria-label="Menú"
        aria-expanded="false"
        aria-controls="nav-menu"
        type="button"
      >
        <i class="las la-bars text-2xl"></i>
      </button>

      <!-- Nav links: collapsed on mobile, flex row on desktop -->
      <div
        id="nav-menu"
        class="nav-menu w-full overflow-hidden lg:flex lg:w-auto lg:items-center lg:gap-1 lg:overflow-visible"
      >
        {
          navigation.items.map((item) => (
            <a
              href={item.url}
              class="nav-link block rounded px-4 py-2 text-sm transition-colors"
              style="color: rgb(196, 205, 213);"
            >
              {item.name}
            </a>
          ))
        }
      </div>
    </nav>
  </div>
</section>

<style>
  /* Mobile: animate max-height for expand/collapse */
  @media (max-width: 1023px) {
    .nav-menu {
      max-height: 0;
      opacity: 0;
      transition: max-height 0.3s ease, opacity 0.2s ease;
    }

    .nav-menu.open {
      max-height: 300px;
      margin-top: 0.5rem;
      opacity: 1;
    }
  }

  /* Desktop: no animation needed, always visible */
  @media (min-width: 1024px) {
    .nav-menu {
      max-height: none;
      opacity: 1;
    }
  }
</style>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("nav-menu");

  toggle?.addEventListener("click", () => {
    const isExpanded = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!isExpanded));
    menu?.classList.toggle("open");
  });

  // Close mobile menu when a link is clicked
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      if (window.innerWidth < 1024) {
        toggle?.setAttribute("aria-expanded", "false");
        menu.classList.remove("open");
      }
    });
  });

  // Scroll spy — highlight the active nav link based on scroll position
  function updateActiveLink() {
    const links = document.querySelectorAll<HTMLAnchorElement>(".nav-link");
    const sections = Array.from(links)
      .map((link) => {
        const id = link.getAttribute("href")?.replace("#", "");
        return id ? document.getElementById(id) : null;
      })
      .filter(Boolean) as HTMLElement[];

    const scrollY = window.scrollY + 120;

    let activeIndex = 0;
    for (let i = sections.length - 1; i >= 0; i--) {
      if (sections[i].offsetTop <= scrollY) {
        activeIndex = i;
        break;
      }
    }

    links.forEach((link, i) => {
      if (i === activeIndex) {
        link.style.color = "#5ce1e6";
        link.style.fontWeight = "700";
      } else {
        link.style.color = "rgb(196, 205, 213)";
        link.style.fontWeight = "400";
      }
    });
  }

  window.addEventListener("scroll", updateActiveLink, { passive: true });
  updateActiveLink();
</script>
