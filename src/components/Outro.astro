<section class="bg-bg-section py-16" id="glovo">
  <div class="mx-auto max-w-4xl px-4">
    <div class="space-y-8">
      <!-- Glovo delivery -->
      <div class="text-center">
        <h3 class="mb-4 text-xl font-semibold">
          <i class="las la-motorcycle"></i> También estamos en Glovo
        </h3>
        <div class="flex justify-center">
          <a
            target="_blank"
            rel="noreferrer"
            href="https://glovoapp.com/es/es/zaragoza/maremoto-beach/"
            class="flex w-full max-w-lg items-center justify-center gap-3 rounded-lg bg-white/10 px-6 py-3 font-semibold transition-colors duration-200 hover:bg-white/20"
          >
            Pide a domicilio
            <img
              src="/images/glovo.jpg"
              alt="Glovo"
              width="256"
              height="256"
              class="hidden h-6 w-6 md:inline-block"
            />
          </a>
        </div>
      </div>

      <!-- Jobs -->
      <div class="text-center">
        <h3 class="mb-2 text-xl font-semibold">
          <i class="las la-users"></i> ¿Quieres trabajar con nosotros?
        </h3>
        <p class="mb-4 text-text/80">
          ¡Próxima incorporación de personal para diferentes puestos!
        </p>
        <div class="flex justify-center">
          <a
            target="_blank"
            rel="noreferrer"
            href="mailto:maremotocafe@hotmail.com"
            class="w-full max-w-lg rounded-lg bg-white/10 px-6 py-3 font-semibold transition-colors duration-200 hover:bg-white/20"
          >
            Déjanos tu curriculum en maremotocafe@hotmail.com
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
