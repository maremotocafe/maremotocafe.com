---
---

<section class="bg-bg-section py-16" id="glovo">
  <div class="mx-auto max-w-4xl px-4">
    <div class="grid gap-6 md:grid-cols-2">
      <!-- Glovo delivery -->
      <div class="flex flex-col items-center justify-center rounded-xl border border-white/10 bg-white/5 px-8 py-8 text-center">
        <h3 class="mb-2 text-xl font-semibold">
          <i class="las la-motorcycle"></i> También estamos en Glovo
        </h3>
        <p class="mb-4 text-text/80">
          Recibe tu pedido en casa sin moverte del sofá
        </p>
        <a
          target="_blank"
          rel="noreferrer"
          href="https://glovoapp.com/es/es/zaragoza/maremoto-beach/"
          class="inline-flex items-center justify-center gap-3 rounded-lg bg-white/10 px-6 py-3 font-semibold text-white transition-colors duration-200 hover:bg-white/20"
        >
          Pide a domicilio
          <img
            src="/images/glovo.jpg"
            alt="Glovo"
            width="256"
            height="256"
            class="inline-block h-6 w-6"
          />
        </a>
      </div>

      <!-- Jobs -->
      <div class="flex flex-col items-center justify-center rounded-xl border border-white/10 bg-white/5 px-8 py-8 text-center">
        <h3 class="mb-2 text-xl font-semibold">
          <i class="las la-users"></i> ¿Quieres trabajar con nosotros?
        </h3>
        <p class="mb-4 text-text/80">
          ¡Próxima incorporación de personal para diferentes puestos!
        </p>
        <a
          target="_blank"
          rel="noreferrer"
          href="mailto:maremotocafe@hotmail.com"
          class="inline-block rounded-lg bg-white/10 px-6 py-3 font-semibold text-white transition-colors duration-200 hover:bg-white/20"
        >
          Déjanos tu curriculum en maremotocafe@hotmail.com
        </a>
      </div>
    </div>
  </div>
</section>
