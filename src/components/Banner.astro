---
import { banner } from "../data/site";
---

<section
  class="relative flex min-h-screen items-center justify-center bg-cover bg-center bg-no-repeat"
  style={`background-image: url("${banner.bgImage}")`}
>
  <div class="absolute inset-0 bg-black/70"></div>
  <div class="relative z-10 w-full px-4 text-center">
    {
      banner.logoTitle ? (
        <img
          src={banner.logoTitle}
          alt={banner.title}
          width="377"
          height="52"
          class="mx-auto mb-3 max-w-md"
        />
      ) : (
        <h1 class="mb-4 text-5xl font-bold">{banner.title}</h1>
      )
    }
    <div class="mx-auto max-w-lg space-y-1 text-lg italic text-white/90">
      {
        banner.content.split("\n\n").map((line) => (
          <p>{line.replace(/\*/g, "")}</p>
        ))
      }
    </div>
    <a
      href={banner.button.link}
      class="mt-8 inline-block border border-white bg-black/50 px-12 py-3.5 font-bold tracking-wide text-white shadow-[0_3px_6px_rgba(255,255,255,0.2)] transition-[opacity,transform] duration-200 hover:scale-105 hover:opacity-90"
    >
      {banner.button.label}
    </a>
  </div>
</section>
